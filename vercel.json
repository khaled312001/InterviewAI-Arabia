{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "backend/public",
  "installCommand": "npm run install:all",
  "framework": null,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/test",     "destination": "/api/test" },
    { "source": "/api/(.*)",     "destination": "/api/index.js" },
    { "source": "/admin",        "destination": "/admin/index.html" },
    { "source": "/admin/(.*)",   "destination": "/admin/index.html" },
    { "source": "/_expo/(.*)",   "destination": "/web/_expo/$1" },
    { "source": "/assets/(.*)",  "destination": "/web/assets/$1" },
    { "source": "/metadata.json","destination": "/web/metadata.json" },
    { "source": "/((?!api/|admin/|_expo/|assets/|web/|favicon|robots|sitemap).*)", "destination": "/web/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 22 * * *"
    }
  ],
  "headers": [
    {
      "source": "/_expo/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/admin/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
