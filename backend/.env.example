# Backend environment variables
# Copy to .env on the server and fill in real values. Never commit .env.

# Server
NODE_ENV=production
PORT=4000

# Database (Hostinger MySQL) - replace credentials before deploying
DATABASE_URL="mysql://u492425110_Interview:REPLACE_ME@srv2070.hstgr.io:3306/u492425110_Interview"

# JWT
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI provider — pick ONE and set its key.
# "groq" is the default (free tier, Llama 3.3 70B, OpenAI-compatible).
AI_ENABLED=false
AI_PROVIDER=groq
AI_MODEL=

# Groq — get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (alternative, free tier for some models) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini (alternative, free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude (still supported if you later want to switch)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_ENABLED=false

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=https://intervie-ai-arabia.barmagly.tech,http://localhost:5173

# Google Play Billing (optional for launch; stub until you add a service account key)
GOOGLE_PLAY_PACKAGE_NAME=tech.barmagly.interviewai
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_ENABLED=false

# Free tier
FREE_DAILY_QUESTION_LIMIT=5

# Admin bootstrap (only used on first seed)
ADMIN_EMAIL=admin@barmagly.tech
ADMIN_PASSWORD=ChangeMeImmediately!
